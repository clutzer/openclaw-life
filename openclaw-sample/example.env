# -----------------------------------------------------------------------
# OpenClaw instance environment — copy to .env and fill in values.
# Never commit .env to Git.
# -----------------------------------------------------------------------

# Variables for docker-compose.yml itself:
OPENCLAW_NAME=      # A short name for this instance, used in container names and log prefixes.  E.g. henry
OPENCLAW_HOSTNAME=  # The public hostname Traefik will route to this instance.  E.g. henry.example.com

# Gateway auth token.  Clients (WebChat, CLI, macOS app) must present this.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Timezone (e.g. America/New_York, Europe/Berlin).  Defaults to UTC.
TZ=UTC

# -----------------------------------------------------------------------
# AI provider credentials — set whichever provider(s) you configure in
# openclaw.json.  Only the vars your chosen model needs are required.
# -----------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Claude web session auth (alternative to API key — see OpenClaw docs).
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# -----------------------------------------------------------------------
# Optional / advanced
# -----------------------------------------------------------------------

# Set to "1" to allow the private WebSocket to connect over plain HTTP.
# Useful during local development without TLS.
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=

# Discord bot token for integration with a Discord bot.  See OpenClaw docs for details.
DISCORD_BOT_TOKEN=

# UID/GID overrides for the OpenClaw process inside the container.  By default, OpenClaw runs as a non-root user with UID and GID 1000.  You can set these to match your host user to avoid file permission issues with mounted volumes.  E.g. if your host user has UID 1001 and GID 1001, set both to 1001 here.
UID=
GID=
