.env

# Runtime data managed by Docker (credentials, sessions, caches).
# These live in the named Docker volume, not in this repo.
# If you ever bind-mount .openclaw directly instead of using a named volume,
# add exclusions here to avoid accidentally committing secrets:
#   .openclaw/credentials/
#   .openclaw/sessions/
#   .openclaw/tmp/

