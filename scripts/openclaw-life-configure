#!/usr/bin/env python3

import os
import sys

def list_openclaw_dirs(base_dir):
    return sorted([
        d for d in os.listdir(base_dir)
        if d.startswith("openclaw-") and os.path.isdir(os.path.join(base_dir, d))
    ])

def select_instance_dir(base_dir):
    dirs = list_openclaw_dirs(base_dir)
    if not dirs:
        print("No openclaw-* directories found. Exiting.")
        exit(1)
    print("Select an openclaw instance:")
    for idx, d in enumerate(dirs, 1):
        print(f"  {idx}. {d}")
    while True:
        choice = input(f"Enter number (1-{len(dirs)}): ").strip()
        if choice.isdigit() and 1 <= int(choice) <= len(dirs):
            return os.path.join(base_dir, dirs[int(choice)-1])
        print("Invalid selection. Try again.")

def main():
    base_dir = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
    if len(sys.argv) > 1:
        instance_dir = os.path.join(base_dir, sys.argv[1])
        if not os.path.isdir(instance_dir):
            print(f"Directory {instance_dir} does not exist. Exiting.")
            exit(1)
    else:
        instance_dir = select_instance_dir(base_dir)


    example_env_path = os.path.join(instance_dir, "example.env")
    dotenv_path = os.path.join(instance_dir, ".env")

    if not os.path.isfile(example_env_path):
        print(f"example.env not found in {instance_dir}.")
        exit(1)

    if os.path.isfile(dotenv_path):
        overwrite = input(f".env already exists in {instance_dir}. Overwrite? [y/N]: ").strip().lower()
        if overwrite != 'y':
            print("Aborted. .env not overwritten.")
            return

    with open(example_env_path, "r") as f:
        lines = f.readlines()


    import subprocess

    # Determine instance name from directory
    instance_basename = os.path.basename(instance_dir)
    openclaw_name = instance_basename.split('-', 1)[1] if '-' in instance_basename else instance_basename

    new_env_lines = []
    def prompt_with_default(prompt, default=None):
        if default:
            prompt = f"{prompt} [default: {default}]: "
        else:
            prompt = f"{prompt}: "
        user_input = input(prompt).strip()
        if user_input:
            return user_input
        return default

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith('#'):
            new_env_lines.append(line)
            continue
        if '=' not in line:
            new_env_lines.append(line)
            continue
        key, value = line.split('=', 1)
        key = key.strip()
        value = value.strip()

        # Custom handling for specific variables
        if key == "OPENCLAW_NAME":
            print(f"Setting OPENCLAW_NAME to '{openclaw_name}' based on directory name.")
            new_env_lines.append(f"OPENCLAW_NAME={openclaw_name}\n")
        elif key == "DISCORD_BOT_TOKEN":
            use_discord = prompt_with_default("Are you going to be integrating this with Discord? [y/N]", "n").lower()
            if use_discord == 'y':
                token = prompt_with_default("Enter your Discord Bot Token", value)
                new_env_lines.append(f"DISCORD_BOT_TOKEN={token}\n")
            else:
                new_env_lines.append(f"DISCORD_BOT_TOKEN=\n")
        elif key == "OPENCLAW_GATEWAY_TOKEN":
            user_value = prompt_with_default("Enter value for OPENCLAW_GATEWAY_TOKEN (leave blank to autogenerate)", value)
            if user_value:
                new_env_lines.append(f"OPENCLAW_GATEWAY_TOKEN={user_value}\n")
            elif value:
                new_env_lines.append(f"OPENCLAW_GATEWAY_TOKEN={value}\n")
            else:
                try:
                    token = subprocess.check_output(["openssl", "rand", "-hex", "32"]).decode().strip()
                    print(f"Autogenerated OPENCLAW_GATEWAY_TOKEN: {token}")
                    new_env_lines.append(f"OPENCLAW_GATEWAY_TOKEN={token}\n")
                except Exception as e:
                    print(f"Failed to generate token: {e}")
                    new_env_lines.append(f"OPENCLAW_GATEWAY_TOKEN=\n")
        else:
            user_value = prompt_with_default(f"Enter value for {key}", value)
            if user_value is not None:
                new_env_lines.append(f"{key}={user_value}\n")
            else:
                new_env_lines.append(f"{key}=\n")

    with open(dotenv_path, "w") as f:
        f.writelines(new_env_lines)

    print(f".env file created at {dotenv_path}")

if __name__ == "__main__":
    main()